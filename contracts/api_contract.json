{
  "InputSchema": {
    "description": "Incoming disruption alert payload generated by backend/sensors.",
    "type": "object",
    "properties": {
      "disruption_id": { "type": "string", "example": "evt-1a2b3c" },
      "type": { "type": "string", "enum": ["delay", "shortage", "failure"] },
      "severity": { "type": "integer", "minimum": 1, "maximum": 10 },
      "node_id": { "type": "string", "example": "NODE_A" }
    },
    "required": ["disruption_id", "type", "severity", "node_id"]
  },
  "OutputSchema": {
    "description": "Response array returned by the memory engine to the AI agents.",
    "type": "object",
    "properties": {
      "recommended_solutions": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "supplier": { "type": "string", "example": "Supplier_1" },
            "action_taken": { "type": "string", "example": "reselect_supplier" },
            "success_score": { "type": "number", "example": 92.4 },
            "expected_cost": { "type": "number", "example": 1500.00 },
            "expected_time_saved": { "type": "number", "example": 12.5 }
          }
        }
      }
    }
  }
}
